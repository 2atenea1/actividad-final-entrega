# Variables de entorno para prueba local con Docker Compose.
# Copia este archivo como .env y reemplaza los valores.

# Pokemon - MySQL en Railway
POKEMON_DB_HOST=tu-host-mysql
POKEMON_DB_PORT=3306
POKEMON_DB_USER=tu-usuario
POKEMON_DB_PASSWORD=tu-password
POKEMON_DB_NAME=pokemon_db

# Naruto - PostgreSQL en Supabase
# Usar formato JDBC para Spring Boot.
NARUTO_DATABASE_URL=jdbc:postgresql://HOST:PORT/postgres?user=USUARIO&password=PASSWORD&sslmode=require

# Dragon Ball - MongoDB Atlas
DRAGONBALL_MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
DRAGONBALL_MONGODB_DB=dragonball_db
